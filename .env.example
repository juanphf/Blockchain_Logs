# Configurações do Nó
NODE_PORT=5000
# NODE_ID=node_01

# Configurações do Gerador de Logs
LOG_SEED=20260406

# Configurações do Kafka
KAFKA_BROKER=localhost:9092
TOPIC_LOGS=audit_logs
TOPIC_BLOCKS=new_blocks

# Controles de Velocidade
# Tempo de espera entre a geração de cada log (em segundos)
DELAY_LOG=2.0 

# Tempo de espera para fechar um bloco de 10 logs (em segundos)
DELAY_BLOCK=3.0